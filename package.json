{
  "name": "lolicode",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/hackycy-collection/lolicode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hackycy-collection/lolicode.git"
  },
  "bugs": "https://github.com/hackycy-collection/lolicode/issues",
  "keywords": [],
  "sideEffects": false,
  "scripts": {
    "build": "nr -r build",
    "dev": "nr -r dev",
    "lint": "eslint --cache .",
    "prepublishOnly": "nr build",
    "release": "bumpp -r",
    "test": "nr -r test",
    "typecheck": "tsc",
    "prepare": "simple-git-hooks",
    "open:packages": "npx open-packages-on-npm",
    "catalog": "pnpx codemod pnpm/catalog"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@antfu/ni": "^27.0.1",
    "@antfu/utils": "^9.3.0",
    "@types/node": "^24.10.0",
    "bumpp": "^10.3.1",
    "eslint": "^9.39.1",
    "lint-staged": "^16.2.6",
    "publint": "^0.3.17",
    "simple-git-hooks": "^2.13.1",
    "tinyexec": "^1.0.2",
    "tsdown": "^0.16.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.7",
    "vitest-package-exports": "^0.1.1",
    "yaml": "^2.8.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
